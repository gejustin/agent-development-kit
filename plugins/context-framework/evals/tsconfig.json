{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": ["self-conformance/**/*.ts", "self-discovery/**/*.ts"]
}
